    "minimap.selectionHighlight": "#0F8B85AA",
    "minimap.errorHighlight": "#C13F4E",
    "minimap.warningHighlight": "#C97F0A",
    "focusBorder": "#0F8B85",
    "foreground": "#2F4A6F",
    "errorForeground": "#C13F4E",
    "selection.background": "#0F8B8540"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7A8090",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#0E8A56"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#0E7AA0"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#2F4A6F"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#0E7AA0"
      }
    },
    {
      "scope": [
        "variable.other.enummember",
        "constant.other.enum",
        "entity.name.constant.enum"
      ],
      "settings": {
        "foreground": "#D85F3F"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#C97F0A"
      }
    },
    {
      "scope": [
        "keyword.control"
      ],
      "settings": {
        "foreground": "#C97F0A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#D85F3F"
      }
    },
    {
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "support.class",
        "support.type",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#0F8B85"
      }
    },
    {
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#C13F4E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#2F4A6F"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#C97F0A"
      }
    },
    {
      "scope": [
        "string.regexp",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#0F8B85"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#C97F0A"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#5A6878"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#D85F3F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#C97F0A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#C97F0A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#0E8A56"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#C13F4E"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#C97F0A"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#C13F4E",
        "fontStyle": "underline"
      }
    }
  ]
}
